	COAST_DWARFS,
	MT_DWARFS,
	RIDGE_DWARFS,
	FIRE_DWARFS,
	FOREST_DWARFS,
	RAVINE_DWARFS,

	DARK_BEASTS,

	BAY_HUMANS,
	RAVINE_HUMANS,
	FOREST_HUMANS,
	CASTLE_HUMANS,
	TROPIC_HUMANS,
	COAST_HUMANS,

	HEART_OF_THE_NATURE,

	DESERT_EMPIRE,

	NORD_ELVES,
	MAINLAND_ELVES,
	BAY_ELVES,
	COAST_ELVES,
}

var FACTIONS_TEXT: Dictionary[FACTIONS, String] = {
	FACTIONS.COAST_DWARFS: "COAST_DWARFS",
	FACTIONS.MT_DWARFS: "MT_DWARFS",
