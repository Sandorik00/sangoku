	FACTIONS.RAVINE_HUMANS: "RAVINE_HUMANS",
	FACTIONS.FOREST_HUMANS: "FOREST_HUMANS",
	FACTIONS.CASTLE_HUMANS: "CASTLE_HUMANS",
	FACTIONS.TROPIC_HUMANS: "TROPIC_HUMANS",
	FACTIONS.COAST_HUMANS: "COAST_HUMANS",

