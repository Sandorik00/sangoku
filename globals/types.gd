extends Node

enum TEAMS {
	BLUE = 1 << 0,
	RED = 1 << 1,
	GREEN = 1 << 2,
	YELLOW = 1 << 3,
}

enum TEAM_MAPPING {
	BLUE = TEAMS.RED | TEAMS.YELLOW,
	RED = TEAMS.BLUE | TEAMS.GREEN,
	GREEN = TEAMS.RED | TEAMS.YELLOW,
	YELLOW = TEAMS.RED | TEAMS.BLUE | TEAMS.GREEN,
}

const TEAMS_MAPPING_TO_MAPPINGS: Dictionary[TEAMS, TEAM_MAPPING] = {
	TEAMS.BLUE: TEAM_MAPPING.BLUE,
	TEAMS.RED: TEAM_MAPPING.RED,
	TEAMS.GREEN: TEAM_MAPPING.GREEN,
	TEAMS.YELLOW: TEAM_MAPPING.YELLOW,
}

